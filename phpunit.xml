<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>

        <!--
            Every external provider is PINNED to its offline fake, so the suite can
            never reach a vendor even when .env holds real keys and real drivers.

            This is not tidiness. Without it the suite inherits whatever the
            developer happens to have enabled: the moment LLM_DRIVER=claude landed
            in .env, tests started making REAL Claude calls — cost, latency, and
            nondeterministic results — and two tests began failing for reasons that
            had nothing to do with the code under test.

            A test run must mean the same thing on every machine and in CI.
        -->
        <env name="LLM_DRIVER" value="fake"/>
        <env name="ANALYSIS_LLM_DRIVER" value="fake"/>
        <env name="WEBSITE_ANALYZER_DRIVER" value="fake"/>
        <env name="TELEPHONY_DRIVER" value="fake"/>
        <env name="TRANSCRIPTION_DRIVER" value="fake"/>
        <env name="EMBEDDINGS_DRIVER" value="fake"/>
        <env name="ANTHROPIC_API_KEY" value=""/>
        <env name="VOYAGE_API_KEY" value=""/>

        <!--
            OUTBOUND IS PINNED OFF. Without this the suite inherits .env — and once
            OUTBOUND_ENABLED=true and real OpenAI/Sonetel credentials were present,
            a test that dialled without faking HTTP would have placed a REAL PHONE
            CALL to a REAL PERSON from `php artisan test`.

            It also made "dials nothing at all with the default configuration" fail,
            which is the test whose entire job is proving the safe default is safe.
            A test suite must describe the code, never the developer's .env.
        -->
        <env name="OUTBOUND_ENABLED" value="false"/>
        <env name="OUTBOUND_TEST_NUMBERS" value=""/>
        <env name="OUTBOUND_ALLOW_WITHOUT_REGISTER_SCREENING" value="false"/>
        <env name="OUTBOUND_REGISTER_SCREENING" value="none"/>
        <env name="OPENAI_API_KEY" value=""/>
        <env name="OPENAI_PROJECT_ID" value=""/>
        <env name="OPENAI_WEBHOOK_SECRET" value=""/>
    </php>
</phpunit>
